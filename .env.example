# MySQL Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_NAME=storybook_db
DB_USER=storybook
DB_PASSWORD=storybook123

# Core Settings
PORT=8080

# Chat Model: gemini, openai, or anthropic
CHAT_MODEL=gemini

# Image Model: openai, leonardo, or none
IMAGE_MODEL=leonardo

# Gemini API (Google)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Leonardo AI Image Generation
LEONARDO_API_KEY=your_leonardo_api_key_here
LEONARDO_MODEL_ID=b24e16ff-06e3-43eb-8d33-4416c2d75876
LEONARDO_WIDTH=512
LEONARDO_HEIGHT=512
LEONARDO_ALCHEMY=false
LEONARDO_NUM_INFERENCE_STEPS=10
LEONARDO_ENHANCE_PROMPT=false
LEONARDO_HIGH_RESOLUTION=false

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Configuration
JWT_SECRET=YourSecretKeyMustBeAtLeast32CharactersLongHere123!
JWT_EXPIRATION_MS=86400000

# Admin Settings
ADMIN_AUDIT_PASSWORD=admin123
ADMIN_AUDIT_ALLOWED_IP=127.0.0.1

# PDF Generation
GENERATE_PDF_IMAGE_ENABLE=true

# Frontend URL (for OAuth2 redirects)
FRONTEND_URL=http://localhost:4200

# Logging
LOG_LEVEL=INFO